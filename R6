-- Function to calculate ADS sensitivities
function CalculateADSSens(scopeMultiplier, FOVMultiplier)
  return math.floor((scopeMultiplier / (FOVMultiplier / 
    (math.tan((FOVMultiplier * FOV) * math.pi / 180 / 2) / 
     math.tan(FOV * math.pi / 180 / 2)))) * 
    XFactor * FOVMultiplier * Sens)
end
 
