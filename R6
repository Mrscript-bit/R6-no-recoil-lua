  SetupInitialRecoils(x + y)
  r_o = r_p[op] or {}
  if debug == true then OutputLogMessage("Setting recoil to %s, (%s)\n", r_o, op) end
  Log()
end
     
function QuickPeek(firstKey, secondKey)
  PressKey(firstKey)
  Sleep(72)  -- 0.072 seconds
  ReleaseKey(firstKey)
  Sleep(13)  -- 0.013 seconds
  PressKey(secondKey)
  Sleep(47)  -- 0.047 seconds
  ReleaseKey(secondKey)
end
 
function OnEvent(event, arg)
  EnablePrimaryMouseButtonEvents(true)
  
  -- Add quick peek detection for Q and E keys
  if event == "G_PRESSED" then
    -- Quick peek right (E then Q)
    if arg == "e" then
      QuickPeek("e", "q")
      return
    end
    
    -- Quick peek left (Q then E)
    if arg == "q" then
      QuickPeek("q", "e")
      return
    end
  end
  
  -- Add settings lock toggle with Alt+Mouse5
  if event == "MOUSE_BUTTON_PRESSED" and arg == 5 and IsModifierPressed(mod) then
    settings_locked = not settings_locked
    Log() -- Update display to show locked status
    return
  end
  
  -- Handle recoil control first (so it always works regardless of lock)
  if event == "MOUSE_BUTTON_PRESSED" then
    if arg == 1 and IsMouseButtonPressed(3) and not IsKeyLockOn(disabler) and not IsModifierPressed(mod) then
      for xy = 3, #r_o, 3 do
        local c_t = GetRunningTime()
        local h_r = r_o[xy-2]
        local v_r = r_o[xy-1]
        local r_d = r_o[xy]
        repeat
          local d_t = GetRunningTime() - c_t
          MoveMouseRelative(h_r, v_r)
          Sleep(10)
        until d_t >= r_d or not IsMouseButtonPressed(1) or not IsMouseButtonPressed(3) or IsModifierPressed(mod) or IsKeyLockOn(disabler)
        if not IsMouseButtonPressed(1) or not IsMouseButtonPressed(3) or IsModifierPressed(mod) or IsKeyLockOn(disabler) then break end
      end
      return
    end
    
    -- Block settings changes if locked
    if settings_locked and IsModifierPressed(mod) then
      if arg == 3 or arg == 1 or arg == 2 or arg == 4 then
        return -- Block team/operator/scope changes when locked
      end
      return
    end
    
    -- Alt + Mouse3 to switch teams
    if arg == 3 and IsModifierPressed(mod) then
      if team == "att" then
        team = "def"
        op = deffs[1] -- Default to first defender
      else
        team = "att" 
        op = atts[1] -- Default to first attacker
      end
      UpdateRec()
      return
    end
    
    -- Alt + Mouse1/2 to cycle operators
    if (arg == 1 or arg == 2) and IsModifierPressed(mod) then
      local ops_list = team == "att" and atts or deffs
      local current_index = indexOf(ops_list, op) or 1
      
      if arg == 1 then -- Next operator
        current_index = current_index + 1
        if current_index > #ops_list then current_index = 1 end
      else -- Previous operator 
        current_index = current_index - 1
        if current_index < 1 then current_index = #ops_list end
      end
      
      op = ops_list[current_index]
      UpdateRec()
      return
    end
  end
  
  if event == "MOUSE_BUTTON_PRESSED" and IsModifierPressed(mod) then
    -- Cycle scopes with Mouse4/5 if operator selected
    if arg == 4 or arg == 5 and op then
      local scopes = {"1x", "1.5x", "2x", "2.5x", "3x", "4x", "5x", "12x"}
      local currentScope = attachments[op].sight
      local currentIndex = indexOf(scopes, currentScope) or 1
      
      if arg == 4 then -- Next scope
        currentIndex = currentIndex + 1
        if currentIndex > #scopes then currentIndex = 1 end
      else -- Previous scope
        currentIndex = currentIndex - 1 
        if currentIndex < 1 then currentIndex = #scopes end
      end
      
      attachments[op].sight = scopes[currentIndex]
      UpdateRec()
    end
  end
end
     
function indexOf(array, value)
  for i, v in ipairs(array) do
    if v == value then
      return i
    end
  end
  return nil
end
     
UpdateRec()
